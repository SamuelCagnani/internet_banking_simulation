{
  "title": "Infraestrutura",
  "uid": "sprint1-infra",
  "tags": ["infra", "sprint1"],
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "title": "Requests por Segundo",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Latencia Media (segundos)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "fillOpacity": 25, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Taxa de Erro por Segundo",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total[1m]))",
          "legendFormat": "Total erros/s"
        },
        {
          "expr": "rate(http_errors_total[1m])",
          "legendFormat": "{{status_code}} — {{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "transparent", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": { "fillOpacity": 25, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 }
    },
    {
      "title": "Distribuicao por Status HTTP",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(status_code) (rate(http_requests_total[5m]))",
          "legendFormat": "{{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 }
    },
    {
      "title": "Total de Requests (ultimos 5min)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 18 }
    },
    {
      "title": "Latencia P50",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 18 }
    },
    {
      "title": "Latencia P95",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 18 }
    },
    {
      "title": "Taxa de Erro %",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_errors_total[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 18 }
    },
    {
      "title": "Throughput Total (req/s)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 18 }
    },
    {
      "title": "Erros/Min",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(http_errors_total[1m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 18 }
    }
  ],
  "schemaVersion": 38,
  "version": 2
}
