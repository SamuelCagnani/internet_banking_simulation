{
  "title": "Incidentes",
  "uid": "sprint5-incidentes",
  "tags": ["incidentes", "sprint5", "chaos", "sre"],
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "title": "Incidentes Ativos",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "active_incidents_total", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 }
    },
    {
      "title": "CPU Simulada",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "simulated_cpu_usage", "legendFormat": "CPU %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 }
    },
    {
      "title": "Memoria Simulada",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "simulated_memory_usage", "legendFormat": "MEM %" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 }
    },
    {
      "title": "Service Down Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "service_down_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "gridPos": { "h": 5, "w": 3, "x": 12, "y": 0 }
    },
    {
      "title": "Timeout Events",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "timeout_events_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "gridPos": { "h": 5, "w": 3, "x": 15, "y": 0 }
    },
    {
      "title": "Internal Errors",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "internal_errors_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "pink", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "gridPos": { "h": 5, "w": 3, "x": 18, "y": 0 }
    },
    {
      "title": "Overload Events",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "overload_events_total" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "gridPos": { "h": 5, "w": 3, "x": 21, "y": 0 }
    },
    {
      "title": "Incidentes por Tipo (taxa/min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(service_down_total[1m]) * 60", "legendFormat": "Service Down" },
        { "expr": "rate(timeout_events_total[1m]) * 60", "legendFormat": "Timeout" },
        { "expr": "rate(internal_errors_total[1m]) * 60", "legendFormat": "Erro 500" },
        { "expr": "rate(overload_events_total[1m]) * 60", "legendFormat": "Overload" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "none" } }
        }
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 }
    },
    {
      "title": "Latencia de Incidentes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(incident_request_duration_seconds_sum[1m]) / rate(incident_request_duration_seconds_count[1m])", "legendFormat": "{{endpoint}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "fillOpacity": 25, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 }
    },
    {
      "title": "Erros 5xx por Minuto",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(http_errors_total{status_code=~'5..'}[1m]) * 60", "legendFormat": "5xx/min" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "custom": { "fillOpacity": 30, "gradientMode": "opacity", "lineWidth": 2, "showPoints": "never" }
        }
      },
      "options": {
        "legend": { "showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 }
    },
    {
      "title": "Resumo de Incidentes",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "incidents_total OR service_down_total OR timeout_events_total OR internal_errors_total OR overload_events_total",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {},
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
